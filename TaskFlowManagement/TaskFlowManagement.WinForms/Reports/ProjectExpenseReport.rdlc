<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Description>Báo cáo Chi phí và Ngân sách Dự án – TaskFlow Management Giai đoạn 9</Description>
  <Author>TaskFlow Management System</Author>
  <AutoRefresh>0</AutoRefresh>
  <Language>vi-VN</Language>
  <DataSources>
    <DataSource Name="dsTaskFlowSource">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local DataSet */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>dsTaskFlowSource</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsExpenseReport">
      <Query>
        <DataSourceName>dsTaskFlowSource</DataSourceName>
        <CommandText>/* Local Report */</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId"><DataField>ProjectId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="ProjectName"><DataField>ProjectName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ProjectStatus"><DataField>ProjectStatus</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CustomerName"><DataField>CustomerName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ManagerName"><DataField>ManagerName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Budget"><DataField>Budget</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="TotalExpense"><DataField>TotalExpense</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Remaining"><DataField>Remaining</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="UsagePercent"><DataField>UsagePercent</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="IsOverBudget"><DataField>IsOverBudget</DataField><rd:TypeName>System.Boolean</rd:TypeName></Field>
        <Field Name="StartDate"><DataField>StartDate</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="PlannedEndDate"><DataField>PlannedEndDate</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <Body>
    <ReportItems>
      <Rectangle Name="rectReportTitle">
        <ReportItems>
          <Textbox Name="txtReportTitle">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>BÁO CÁO TÀI CHÍNH &amp; NGÂN SÁCH DỰ ÁN</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>18pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <Color>#1E293B</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.3cm</Top>
            <Left>0cm</Left>
            <Height>1cm</Height>
            <Width>20cm</Width>
            <Style>
              <VerticalAlign>Middle</VerticalAlign>
              <PaddingLeft>5pt</PaddingLeft>
            </Style>
          </Textbox>
          <Textbox Name="txtReportSubtitle">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>TaskFlow Management  ·  Báo cáo tự động</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>10pt</FontSize>
                      <Color>#64748B</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>1.3cm</Top>
            <Left>0cm</Left>
            <Height>0.6cm</Height>
            <Width>20cm</Width>
            <Style>
              <VerticalAlign>Middle</VerticalAlign>
              <PaddingLeft>5pt</PaddingLeft>
            </Style>
          </Textbox>
          <!-- Accent Line -->
          <Line Name="lineAccent">
            <Top>2.1cm</Top>
            <Left>0cm</Left>
            <Height>0cm</Height>
            <Width>27.5cm</Width>
            <Style>
              <Border>
                <Color>#3B82F6</Color>
                <Style>Solid</Style>
                <Width>2pt</Width>
              </Border>
            </Style>
          </Line>
        </ReportItems>
        <KeepTogether>true</KeepTogether>
        <Top>0cm</Top>
        <Left>0cm</Left>
        <Height>2.3cm</Height>
        <Width>27.5cm</Width>
        <Style>
          <BackgroundColor>White</BackgroundColor>
        </Style>
      </Rectangle>
      <Tablix Name="tblxExpenseReport">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>6.5cm</Width></TablixColumn>
            <TablixColumn><Width>4.5cm</Width></TablixColumn>
            <TablixColumn><Width>3.5cm</Width></TablixColumn>
            <TablixColumn><Width>3.5cm</Width></TablixColumn>
            <TablixColumn><Width>3.5cm</Width></TablixColumn>
            <TablixColumn><Width>2.5cm</Width></TablixColumn>
            <TablixColumn><Width>3.5cm</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <!-- Header Row -->
            <TablixRow>
              <Height>1cm</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="hProjectName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>TÊN DỰ ÁN</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>10pt</PaddingLeft><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hCustomer"><Paragraphs><Paragraph><TextRuns><TextRun><Value>KHÁCH HÀNG</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>5pt</PaddingLeft><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hBudget"><Paragraphs><Paragraph><TextRuns><TextRun><Value>NGÂN SÁCH</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingRight>5pt</PaddingRight><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hTotalExpense"><Paragraphs><Paragraph><TextRuns><TextRun><Value>ĐÃ CHI</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingRight>5pt</PaddingRight><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hRemaining"><Paragraphs><Paragraph><TextRuns><TextRun><Value>CÒN LẠI</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingRight>5pt</PaddingRight><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hUsagePercent"><Paragraphs><Paragraph><TextRuns><TextRun><Value>TỶ LỆ (%)</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hStatus"><Paragraphs><Paragraph><TextRuns><TextRun><Value>TRẠNG THÁI</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1E293B</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
            <!-- Data Row -->
            <TablixRow>
              <Height>0.9cm</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="dProjectName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ProjectName.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9.5pt</FontSize><FontWeight>Bold</FontWeight><Color>#0F172A</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>10pt</PaddingLeft><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="dCustomerName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!CustomerName.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9.5pt</FontSize><Color>#334155</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>5pt</PaddingLeft><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="dBudget"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!Budget.Value, "N0") &amp; " ₫"</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9.5pt</FontSize><Color>#0F172A</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><PaddingRight>5pt</PaddingRight><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="dTotalExpense"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!TotalExpense.Value, "N0") &amp; " ₫"</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9.5pt</FontSize><Color>=IIF(Fields!IsOverBudget.Value, "#DC2626", "#0F172A")</Color><FontWeight>=IIF(Fields!IsOverBudget.Value, "Bold", "Normal")</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><PaddingRight>5pt</PaddingRight><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="dRemaining"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!Remaining.Value, "N0") &amp; " ₫"</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9.5pt</FontSize><Color>=IIF(Fields!IsOverBudget.Value, "#DC2626", "#059669")</Color><FontWeight>=IIF(Fields!IsOverBudget.Value, "Bold", "Normal")</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><PaddingRight>5pt</PaddingRight><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="dUsagePercent"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!UsagePercent.Value, "N1") &amp; "%"</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9.5pt</FontSize><Color>=IIF(Fields!UsagePercent.Value > 90, "#DC2626", "#0F172A")</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="dStatus"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ProjectStatus.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>=Switch(Fields!ProjectStatus.Value = "Completed", "#16A34A", Fields!ProjectStatus.Value = "InProgress", "#EA580C", Fields!ProjectStatus.Value = "OnHold", "#CA8A04", Fields!ProjectStatus.Value = "Cancelled", "#DC2626", True, "#475569")</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><VerticalAlign>Middle</VerticalAlign><Border><Style>None</Style></Border><BottomBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></BottomBorder><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F1F5F9", "White")</BackgroundColor></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <TablixColumnHierarchy>
          <TablixMembers>
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
          </TablixMembers>
        </TablixColumnHierarchy>
        <TablixRowHierarchy>
          <TablixMembers>
            <TablixMember><KeepWithGroup>After</KeepWithGroup><RepeatOnNewPage>true</RepeatOnNewPage><KeepTogether>true</KeepTogether></TablixMember>
            <TablixMember><Group Name="Details" /><TablixMembers><TablixMember /></TablixMembers></TablixMember>
          </TablixMembers>
        </TablixRowHierarchy>
        <DataSetName>dsExpenseReport</DataSetName>
        <Top>2.8cm</Top>
        <Left>0cm</Left>
        <Height>1.9cm</Height>
        <Width>27.5cm</Width>
        <Style>
          <Border><Style>None</Style></Border>
        </Style>
      </Tablix>
    </ReportItems>
    <Height>6cm</Height>
    <Style>
      <BackgroundColor>White</BackgroundColor>
    </Style>
  </Body>
  <ReportParameters>
    <ReportParameter Name="pReporter">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>Người xuất báo cáo</Prompt>
    </ReportParameter>
    <ReportParameter Name="pExportDate">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <AllowBlank>true</AllowBlank>
      <Prompt>Ngày xuất báo cáo</Prompt>
    </ReportParameter>
  </ReportParameters>
  <Width>27.5cm</Width>
  <Page>
    <PageFooter>
      <Height>1cm</Height>
      <PrintOnFirstPage>true</PrintOnFirstPage>
      <PrintOnLastPage>true</PrintOnLastPage>
      <ReportItems>
        <Textbox Name="txtFooterReporter">
          <CanGrow>true</CanGrow>
          <KeepTogether>true</KeepTogether>
          <Paragraphs>
            <Paragraph>
              <TextRuns>
                <TextRun>
                  <Value>="Người xuất: " &amp; Parameters!pReporter.Value &amp; "     Ngày xuất: " &amp; Parameters!pExportDate.Value</Value>
                  <Style>
                    <FontFamily>Segoe UI</FontFamily>
                    <FontSize>8pt</FontSize>
                    <Color>#94A3B8</Color>
                  </Style>
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Left</TextAlign>
              </Style>
            </Paragraph>
          </Paragraphs>
          <Top>0.2cm</Top>
          <Left>0cm</Left>
          <Height>0.6cm</Height>
          <Width>18cm</Width>
          <Style>
            <VerticalAlign>Middle</VerticalAlign>
          </Style>
        </Textbox>
        <Textbox Name="txtFooterPage">
          <CanGrow>true</CanGrow>
          <KeepTogether>true</KeepTogether>
          <Paragraphs>
            <Paragraph>
              <TextRuns>
                <TextRun>
                  <Value>="Trang " &amp; Globals!PageNumber &amp; " / " &amp; Globals!TotalPages</Value>
                  <Style>
                    <FontFamily>Segoe UI</FontFamily>
                    <FontSize>8pt</FontSize>
                    <Color>#94A3B8</Color>
                  </Style>
                </TextRun>
              </TextRuns>
              <Style>
                <TextAlign>Right</TextAlign>
              </Style>
            </Paragraph>
          </Paragraphs>
          <Top>0.2cm</Top>
          <Left>23.5cm</Left>
          <Height>0.6cm</Height>
          <Width>4cm</Width>
          <Style>
            <VerticalAlign>Middle</VerticalAlign>
          </Style>
        </Textbox>
      </ReportItems>
      <Style>
        <Border><Style>None</Style></Border>
        <TopBorder><Color>#E2E8F0</Color><Style>Solid</Style><Width>1pt</Width></TopBorder>
      </Style>
    </PageFooter>
    <PageHeight>21cm</PageHeight>
    <PageWidth>29.7cm</PageWidth>
    <LeftMargin>1cm</LeftMargin>
    <RightMargin>1cm</RightMargin>
    <TopMargin>1cm</TopMargin>
    <BottomMargin>1cm</BottomMargin>
    <ColumnSpacing>0cm</ColumnSpacing>
    <Style />
  </Page>
</Report>
